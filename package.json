{
  "name": "votepath-india",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://example.com",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs --format=cjs --external:vite --external:express --external:dotenv --external:path --external:url --external:fs",
    "build": "npm run build:client && npm run build:server",
    "start": "NODE_ENV=production node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint src && tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "d3-fetch": "^3.0.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.12.1",
    "gh-pages": "^6.3.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.5",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "topojson-client": "^3.1.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "dompurify": "^3.4.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
